# ==============================================================
# FitTracker - exemple de variables d'environnement (12-Factor III)
# Copier ce fichier en .env (ignore par git) et adapter les valeurs.
# Toutes les valeurs ici sont des EXEMPLES, jamais des secrets reels.
# ==============================================================

# ---- Application ----
APP_NAME=fittracker
APP_VERSION=0.1.0-SNAPSHOT
SERVER_PORT=8080
# 'dev' = console texte coloree ; 'prod' = JSON structure
SPRING_PROFILES_ACTIVE=dev

# ---- Actuator ----
# En prod : exposer seulement health,info. En dev possible : health,info,env,metrics
ACTUATOR_EXPOSE=health,info
ACTUATOR_HEALTH_DETAILS=never

# ---- Logging ----
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SPRING=INFO
# Active la rotation fichier (100 Mo, historique 7 jours). False = stdout uniquement (12-Factor XI).
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs

# ---- Tracing (Micrometer) ----
# 1.0 = 100% des requetes tracees. Reduire en prod (ex. 0.1).
TRACING_SAMPLING_PROBABILITY=1.0

# ---- PostgreSQL (phase 2+ : compose ; consomme reellement en phase 4) ----
POSTGRES_DB=fittracker
POSTGRES_USER=fittracker
POSTGRES_PASSWORD=change-me-please
# URL utilisee par Spring Boot. Depuis l'app dans compose : 'db' est le service.
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/fittracker
SPRING_DATASOURCE_USERNAME=fittracker
SPRING_DATASOURCE_PASSWORD=change-me-please
DB_POOL_MAX=10
DB_POOL_MIN=2

# ---- Redis (phase 2+ : compose ; consomme phase 5) ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2000

# ---- Nginx / reverse-proxy ----
NGINX_HTTP_PORT=80
# Activer en phase 6 quand le certificat self-signed est genere
# NGINX_HTTPS_PORT=443

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- JWT (phase 6) ----
JWT_ISSUER=fittracker
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800
# Chemins vers les cles RSA, montees en secret par docker compose en phase 6
# JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem

# ---- Docker / registry ----
REGISTRY=ghcr.io/issa9595
IMAGE_NAME=fittracker
