# ==============================================================
# FitTracker - exemple de variables d'environnement
# Copier ce fichier en .env (ignore par git) et adapter les valeurs.
# Phase 1 : seules les vars 'app' sont utilisees. Les autres
# sections seront alimentees aux phases suivantes.
# ==============================================================

# ---- Application ----
APP_NAME=fittracker
APP_VERSION=0.1.0-SNAPSHOT
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ---- Actuator ----
ACTUATOR_EXPOSE=health,info
ACTUATOR_HEALTH_DETAILS=never

# ---- Logging ----
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO

# ---- Database (PostgreSQL, phase 2+) ----
# POSTGRES_DB=fittracker
# POSTGRES_USER=fittracker
# POSTGRES_PASSWORD=change-me
# SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/fittracker
# SPRING_DATASOURCE_USERNAME=fittracker
# SPRING_DATASOURCE_PASSWORD=change-me

# ---- Redis (phase 2+) ----
# REDIS_HOST=redis
# REDIS_PORT=6379

# ---- Securite (phase 6) ----
# JWT_ISSUER=fittracker
# JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem

# ---- Docker / registry ----
REGISTRY=ghcr.io/issa9595
IMAGE_NAME=fittracker
